# Django
SECRET_KEY=replace-with-a-long-random-value
DJANGO_SETTINGS_MODULE=config.Settings.dev
DJANGO_LOG_LEVEL=INFO
DJANGO_ROOT_LOG_LEVEL=WARNING
TIME_ZONE=America/New_York
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# PostgreSQL
DB_NAME=ez360pm
DB_USER=ez360pm
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=
DB_CONN_MAX_AGE=60

# Cache
REDIS_URL=redis://127.0.0.1:6379/1

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Provost Home Design <noreply@example.com>
PUBLIC_BASE_URL=http://localhost:8000

# Uploaded files. In production this path must use a persistent volume.
MEDIA_ROOT=media

# Stripe Checkout (leave blank to keep online payments disabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Initial setup. Remove the password from the environment after bootstrap.
EZ360PM_OWNER_PASSWORD=replace-with-a-strong-initial-password
